{
  "layers": [
    {
      "name": "runtime",
      "paths": ["src/codeatlas/"],
      "forbidden": ["tests", "examples"],
      "severity": "warning",
      "message": "Runtime code must stay independent from tests and examples"
    },
    {
      "name": "tests",
      "paths": ["tests/"],
      "may_depend_on": ["runtime", "examples"]
    },
    {
      "name": "examples",
      "paths": ["examples/"],
      "may_depend_on": ["runtime"]
    }
  ],
  "security": {
    "ignore_paths": ["tests/"],
    "ignore_kinds": [],
    "min_severity": "note"
  },
  "rules": [
    {
      "name": "runtime-must-not-import-tests",
      "from": ["src/codeatlas/"],
      "to": ["tests/"],
      "severity": "warning",
      "message": "Runtime code must not depend on tests"
    },
    {
      "name": "runtime-must-not-import-examples",
      "from": ["src/codeatlas/"],
      "to": ["examples/"],
      "severity": "warning",
      "message": "Runtime code must not depend on examples"
    }
  ]
}
